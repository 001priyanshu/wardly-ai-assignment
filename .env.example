# Copy to .env at repo root and fill in. docker-compose reads this automatically.

# === LLM provider ===
# Choose one: 'anthropic' or 'openai'. Both can be configured; only the active one is required.
LLM_PROVIDER=anthropic

# Anthropic (default; recommended for clinical extraction)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (alternate provider; switch by setting LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# === Server ===
CORS_ORIGIN=http://localhost:3000
TURN_CAP=40

# === Frontend ===
NEXT_PUBLIC_API_BASE=http://localhost:4000
